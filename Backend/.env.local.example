DATABASE_URL=postgresql://postgres.lohjvdwckpjuvtfxdihb:[YOUR-PASSWORD]@aws-1-us-west-2.pooler.supabase.com:6543/postgres

# Alembic migrations need a session-level connection (DDL, search_path) that
# the transaction pooler above (port 6543) doesn't reliably provide. Same
# host/user, just port 5432 for Supabase's session-mode pooling instead.
MIGRATIONS_DATABASE_URL=postgresql://postgres.lohjvdwckpjuvtfxdihb:[YOUR-PASSWORD]@aws-1-us-west-2.pooler.supabase.com:5432/postgres

DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

ALLOWED_ORIGINS=["https://f1-capstone-project-ujwc.onrender.com"]

# OpenWeather API - get your free key at https://openweathermap.org/api
# used for current weather data (60 calls/minute free tier)
OPENWEATHER_API_KEY=your_api_key_here

# Visual Crossing Weather API - get your free key at https://www.visualcrossing.com/sign-up
# used for historical weather data backfill (1,000 calls/day free tier)
VISUALCROSSING_API_KEY=your_api_key_here

# Sentry error tracking - get your DSN at https://sentry.io (FastAPI project).
# SENTRY_ENVIRONMENT distinguishes prod/staging within the same Sentry project.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
