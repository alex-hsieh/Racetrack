DATABASE_URL=postgresql://username:password@localhost:5432/f1_predictor

# Alembic migrations need a session-level connection (DDL, search_path). If
# DATABASE_URL points at a connection pooler in transaction mode (e.g.
# Supabase's port 6543), set this to a session-mode connection string instead
# (Supabase: same host/user, port 5432). Falls back to DATABASE_URL if unset.
MIGRATIONS_DATABASE_URL=

DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# OpenWeather API - get your free key at https://openweathermap.org/api
# used for current weather data (60 calls/minute free tier)
OPENWEATHER_API_KEY=your_api_key_here

# Visual Crossing Weather API - get your free key at https://www.visualcrossing.com/sign-up
# used for historical weather data backfill (1,000 calls/day free tier)
VISUALCROSSING_API_KEY=your_api_key_here

# Sentry error tracking - get your DSN at https://sentry.io (FastAPI project).
# Leave unset to disable (e.g. local dev). SENTRY_ENVIRONMENT distinguishes
# prod/staging within the same Sentry project rather than separate projects.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
