# Racetrack backend API base URL. Defaults to the production backend if unset —
# set this locally (e.g. http://localhost:8000) to point the frontend at a
# local or staging backend instead, without touching any code.
VITE_API_BASE_URL=

# F1 ergast jolipca api url
VITE_JOLPICA_BASE_URL=https://api.jolpi.ca/ergast/f1/

# OpenF1 api url
VITE_OPENF1_BASE_URL=https://api.openf1.org/v1/

# OpenWeather api url
# OpenWeather requires subscription with credit card
# Add after next meeting 2/22

# pick what news feed to use at next meeting 2/22
# Place holder to test with news
VITE_F1_NEWS_URL=https://api.rss2json.com/v1/api.json?rss_url=https://racer.com/category/formula-1/feed

# Sentry error tracking - get your DSN at https://sentry.io (React project).
# Leave unset to disable (e.g. local dev). VITE_SENTRY_ENVIRONMENT distinguishes
# prod/staging within the same Sentry project rather than separate projects.
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development

